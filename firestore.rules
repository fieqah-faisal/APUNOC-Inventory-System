rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserRole() {
      return currentUserDoc().data.role;
    }

    function isSuperAdmin() {
      return signedIn() && currentUserRole() == "super-admin";
    }

    function isAdmin() {
      return signedIn() &&
        (currentUserRole() == "admin" || currentUserRole() == "super-admin");
    }

    function isOperator() {
      return signedIn() && currentUserRole() == "operator";
    }

    function isOperationalUser() {
      return signedIn() &&
        (
          currentUserRole() == "operator" ||
          currentUserRole() == "admin" ||
          currentUserRole() == "super-admin"
        );
    }

    function isOwnUserDoc(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function changedKeys() {
      return request.resource.data.diff(resource.data).changedKeys();
    }

    match /users/{uid} {
      allow read: if isOwnUserDoc(uid) || isAdmin();

      allow create: if isAdmin();

      allow update: if isAdmin()
        || (
          isOwnUserDoc(uid)
          && changedKeys().hasOnly(["lastLogin"])
        );

      allow delete: if false;
    }
    match /assets/{assetId} {
      allow read: if isOperationalUser();

      allow create: if isOperationalUser();

      allow update: if isAdmin()
        || (
          isOperator()
          && changedKeys().hasOnly([
            "status",
            "remarks",
            "updatedAt",
            "updatedBy",
            "issuedToUser",
            "custodian"
          ])
        );

      allow delete: if false;
    }

    match /consumables/{consumableId} {
      allow read: if isOperationalUser();

      allow create: if isOperationalUser();

      allow update: if isOperationalUser();

      allow delete: if false;
    }

    match /locations/{locationId} {
      allow read: if isOperationalUser();

      allow create, update: if isAdmin();

      allow delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();

      allow create: if isOperationalUser();

      allow update, delete: if false;
    }
  }
}